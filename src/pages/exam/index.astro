---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { DOMAINS } from '../../data/domains';

const quiz = await getCollection('quiz');
// Strip the collection wrapper; ship plain question objects to the client.
const questions = quiz.map((q) => q.data);
const domainMeta = Object.fromEntries(DOMAINS.map((d) => [d.id, { name: d.name, weight: d.weight }]));
const poolByDomain = Object.fromEntries(
  DOMAINS.map((d) => [d.id, questions.filter((q) => q.domain === d.id).length]),
);
---

<Base title="Practice Exam">
  <h1>Practice exam</h1>
  <p class="lead">
    Questions are sampled across the five domains using the real exam&rsquo;s weighting. Pass mark is
    set at <strong>72%</strong> (the CCA-F scaled equivalent of 720/1000).
  </p>

  <div id="setup">
    <div class="toolbar">
      <label>Questions:
        <select id="count">
          <option value="10">10 (quick)</option>
          <option value="20" selected>20</option>
          <option value="40">40</option>
          <option value="0">All ({questions.length})</option>
        </select>
      </label>
      <button class="btn" id="start">Start exam</button>
    </div>
    <table class="tablelike">
      <thead><tr><th>Domain</th><th>Weight</th><th>Questions in pool</th></tr></thead>
      <tbody>
        {DOMAINS.map((d) => (
          <tr>
            <td>{d.name}</td>
            <td>{d.weight}%</td>
            <td>{poolByDomain[d.id]}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div id="result" style="display:none"></div>
  <form id="quizForm" style="display:none"></form>
  <div class="toolbar" id="actions" style="display:none">
    <button class="btn" id="submit" type="button">Submit answers</button>
    <button class="btn secondary" id="restart" type="button">New exam</button>
  </div>

  <script is:inline define:vars={{ questions, domainMeta }}>
    const els = {
      setup: document.getElementById('setup'),
      form: document.getElementById('quizForm'),
      actions: document.getElementById('actions'),
      result: document.getElementById('result'),
      count: document.getElementById('count'),
    };
    let current = [];
    let seenIds = new Set();

    function shuffle(arr) {
      const a = arr.slice();
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function pickQuestions(total) {
      const effectiveTotal = (!total || total >= questions.length) ? questions.length : total;

      // Prefer questions not yet seen in this session.
      let pool = questions.filter((q) => !seenIds.has(q.id));
      if (pool.length < effectiveTotal) {
        // Not enough unseen questions — reset and use the full set.
        seenIds = new Set();
        pool = questions.slice();
      }

      if (effectiveTotal >= pool.length) return shuffle(pool);

      const byDomain = {};
      for (const q of pool) (byDomain[q.domain] ||= []).push(q);
      const weightSum = Object.values(domainMeta).reduce((s, d) => s + d.weight, 0);
      let picked = [];
      for (const [id, meta] of Object.entries(domainMeta)) {
        const domPool = shuffle(byDomain[id] || []);
        const n = Math.min(domPool.length, Math.round((meta.weight / weightSum) * effectiveTotal));
        picked.push(...domPool.slice(0, n));
      }
      // Top up / trim to exact count from whatever remains.
      const chosen = new Set(picked);
      const remaining = shuffle(pool.filter((q) => !chosen.has(q)));
      while (picked.length < effectiveTotal && remaining.length) picked.push(remaining.pop());
      return shuffle(picked.slice(0, effectiveTotal));
    }

    function render() {
      els.form.innerHTML = '';
      current.forEach((q, i) => {
        const card = document.createElement('div');
        card.className = 'q';
        card.dataset.answer = q.answer;
        card.dataset.domain = q.domain;
        const opts = q.options
          .map(
            (o, oi) =>
              `<label class="opt"><input type="radio" name="q${i}" value="${oi}"> ${escapeHtml(o)}</label>`,
          )
          .join('');
        card.innerHTML =
          `<div class="qnum">Question ${i + 1} of ${current.length} · ${escapeHtml(domainMeta[q.domain].name)}</div>` +
          `<p><strong>${escapeHtml(q.question)}</strong></p>` +
          opts +
          `<div class="explain"></div>`;
        els.form.appendChild(card);
      });
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]),
      );
    }

    function start() {
      const total = parseInt(els.count.value, 10);
      current = pickQuestions(total);
      current.forEach((q) => seenIds.add(q.id));
      render();
      els.setup.style.display = 'none';
      els.result.style.display = 'none';
      els.form.style.display = '';
      els.actions.style.display = '';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function grade() {
      const cards = [...els.form.querySelectorAll('.q')];
      let correct = 0;
      const byDomain = {};
      const results = [];
      cards.forEach((card, i) => {
        const ans = parseInt(card.dataset.answer, 10);
        const dom = card.dataset.domain;
        byDomain[dom] ||= { correct: 0, total: 0 };
        byDomain[dom].total++;
        const chosen = card.querySelector(`input[name="q${i}"]:checked`);
        const ci = chosen ? parseInt(chosen.value, 10) : null;
        const isCorrect = ci === ans;
        if (isCorrect) { correct++; byDomain[dom].correct++; }
        results.push({ q: current[i], chosen: ci, isCorrect });
      });
      els.form.style.display = 'none';
      const total = cards.length;
      const pct = Math.round((correct / total) * 100);
      showResult(correct, total, pct, byDomain, results);
    }

    function showResult(correct, total, pct, byDomain, results) {
      const pass = pct >= 72;
      let rows = '';
      for (const [id, s] of Object.entries(byDomain)) {
        const dpct = Math.round((s.correct / s.total) * 100);
        rows += `<tr><td>${escapeHtml(domainMeta[id].name)}</td><td>${s.correct}/${s.total}</td><td>${dpct}%</td></tr>`;
      }

      const reviewCards = results.map(({ q, chosen, isCorrect }, i) => {
        const opts = q.options.map((o, oi) => {
          let cls = 'opt';
          if (oi === q.answer) cls += ' correct';
          else if (oi === chosen) cls += ' incorrect';
          return `<div class="${cls}" style="cursor:default">${escapeHtml(o)}</div>`;
        }).join('');
        const skipped = chosen === null
          ? `<div class="opt incorrect" style="cursor:default;margin-bottom:0.25rem">No answer selected</div>`
          : '';
        return (
          `<div class="q answered ${isCorrect ? 'q-correct' : 'q-wrong'}">` +
          `<div class="qnum">Question ${i + 1} of ${results.length} · ${escapeHtml(domainMeta[q.domain].name)}</div>` +
          `<p><strong>${escapeHtml(q.question)}</strong></p>` +
          skipped +
          opts +
          `<div class="explain"><strong>Answer:</strong> ${escapeHtml(q.options[q.answer])}<br>${escapeHtml(q.explanation)}</div>` +
          `</div>`
        );
      }).join('');

      const missedCount = results.filter((r) => !r.isCorrect).length;
      const summaryNote = missedCount === 0
        ? `<p style="color:var(--green);font-weight:600">All correct — nothing to review.</p>`
        : `<p class="muted">${missedCount} incorrect. Review all questions below in the order you answered them.</p>`;

      els.result.innerHTML =
        `<div class="score-banner" style="border-color:${pass ? 'var(--green)' : 'var(--red)'}">` +
        `${pass ? '✓ Pass' : '✗ Keep studying'} — ${correct}/${total} (${pct}%)</div>` +
        `<p class="muted">Pass mark is 72%.</p>` +
        `<table class="tablelike"><thead><tr><th>Domain</th><th>Score</th><th>%</th></tr></thead><tbody>${rows}</tbody></table>` +
        summaryNote +
        `<h2 style="margin-top:2rem;font-size:1.1rem">Question review</h2>` +
        reviewCards;
      els.result.style.display = '';
      els.actions.querySelector('#submit').style.display = 'none';
      els.result.scrollIntoView({ behavior: 'smooth' });
    }

    document.getElementById('start').addEventListener('click', start);
    document.getElementById('submit').addEventListener('click', grade);
    document.getElementById('restart').addEventListener('click', () => {
      els.form.style.display = 'none';
      els.actions.style.display = 'none';
      els.actions.querySelector('#submit').style.display = '';
      els.result.style.display = 'none';
      els.setup.style.display = '';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
</Base>
