---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { DOMAINS } from '../data/domains';

const lessons = await getCollection('lessons');
const exercises = await getCollection('exercises');
const quiz = await getCollection('quiz');

exercises.sort((a, b) => a.data.order - b.data.order);
lessons.sort((a, b) => a.data.order - b.data.order);
---

<Base title="Home">
  <section class="course-hero">
    <div class="course-hero__eyebrow">Claude Certified Architect &mdash; Foundations (CCA-F) Exam Prep</div>
    <h1>Claude Code Academy</h1>
    <p class="lead">
      Master Claude Code and prepare for the CCA-F certification exam through structured lessons,
      hands-on exercises, and practice exams.
    </p>
    <div class="toolbar" style="justify-content:center">
      <a class="btn" href="/lessons/claude-code-workflows/">Start Learning</a>
      <a class="btn secondary" href="/exam/">Practice Exam</a>
    </div>
    <div class="course-stats">
      <div class="course-stat"><span>5</span>Modules</div>
      <div class="course-stat"><span>5</span>Lessons</div>
      <div class="course-stat"><span>{exercises.length}</span>Exercises</div>
      <div class="course-stat"><span>{quiz.length}</span>Quiz Questions</div>
    </div>
  </section>

  <section class="what-is-cc">
    <h2 style="margin-top:0">What is Claude Code?</h2>
    <p class="muted">
      Claude Code is Anthropic&rsquo;s official command-line tool (and IDE extension) that brings
      Claude directly into your codebase. Instead of copying code into a chat window, Claude Code
      reads your files, makes edits, runs commands, and works through multi-step tasks
      autonomously &mdash; from your terminal or editor.
    </p>
    <p class="muted">
      This course is for developers who use Claude Code (or plan to) and want to understand how it
      works deeply enough to use it well &mdash; and optionally prepare for the
      <strong>CCA-F (Claude Certified Architect &mdash; Foundations)</strong> certification. No prior
      Claude Code experience is required, but you should be comfortable with the command line and
      basic software development.
    </p>
  </section>

  <div id="continue-card" class="card" style="display:none;margin-bottom:2rem">
    <p style="margin:0 0 0.1rem;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-dim)">Continue where you left off</p>
    <div id="continue-links" style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:0.6rem"></div>
    <button id="continue-reset" style="margin-top:0.75rem;background:none;border:none;color:var(--text-dim);font-size:0.8rem;cursor:pointer;padding:0">Reset progress</button>
  </div>

  <script>
    (function () {
      var card = document.getElementById('continue-card');
      var linksEl = document.getElementById('continue-links');
      var resetBtn = document.getElementById('continue-reset');
      var KEYS = ['cca-last-lesson', 'cca-last-exercise'];
      var LABELS = ['Lesson', 'Exercise'];

      function load() {
        var items = [];
        for (var i = 0; i < KEYS.length; i++) {
          try {
            var raw = localStorage.getItem(KEYS[i]);
            if (raw) items.push({ label: LABELS[i], data: JSON.parse(raw) });
          } catch (_) {}
        }
        if (items.length === 0) { card.style.display = 'none'; return; }
        linksEl.innerHTML = items.map(function (it) {
          return '<a class="btn secondary" href="' + it.data.url + '">' + it.label + ': ' + it.data.title + ' &rarr;</a>';
        }).join('');
        card.style.display = '';
      }

      resetBtn.addEventListener('click', function () {
        KEYS.forEach(function (k) { try { localStorage.removeItem(k); } catch (_) {} });
        card.style.display = 'none';
      });

      load();
    })();
  </script>

  <h2>Course Curriculum</h2>

  <div style="display:flex;flex-direction:column;gap:0.75rem">
    {DOMAINS.map((d, i) => {
      const domainLessons = lessons.filter((l) => l.data.domain === d.id);
      const domainExercises = exercises.filter((e) => e.data.domain === d.id);
      return (
        <div class="module-card">
          <div class="module-card__header">
            <span class="module-num">Module {i + 1}</span>
            <span class="badge weight">{d.weight}% of exam</span>
            {d.practiceable
              ? <span class="badge beginner">Hands-on</span>
              : <span class="badge concept">Architecture-focused</span>}
          </div>
          <h3>{d.name}</h3>
          <p class="muted" style="margin:0 0 0.25rem;font-size:0.88rem">{d.blurb}</p>
          <ul class="module-objectives">
            {d.objectives.map((o) => <li>{o}</li>)}
          </ul>
          <ul class="module-items">
            {domainLessons.map((l) => (
              <li class="module-item module-item--lesson">
                <span class="module-item__type">Lesson</span>
                <a href={`/lessons/${l.id}/`}>{l.data.title}</a>
                <span class="module-item__meta">{l.data.minutes} min read</span>
              </li>
            ))}
            {domainExercises.map((e) => (
              <li class="module-item module-item--exercise">
                <span class="module-item__type">Exercise</span>
                <a href={`/exercises/${e.id}/`}>{e.data.title}</a>
                <span class={`badge ${e.data.difficulty}`} style="margin-left:auto">{e.data.difficulty}</span>
              </li>
            ))}
          </ul>
        </div>
      );
    })}
  </div>

  <h2 style="margin-top:3rem">How this works</h2>
  <div class="grid cols-2">
    <div class="card">
      <h3>You only need Claude Code</h3>
      <p class="muted">
        Every exercise is self-guided: you run the task in your own Claude Code session, then reveal
        a model solution to compare. No Claude API key or Agent SDK required.
      </p>
    </div>
    <div class="card">
      <h3>{quiz.length} practice questions</h3>
      <p class="muted">
        The practice exam draws from a pool tagged by domain and scores you the way the real exam
        weights each area, with an explanation for every answer.
      </p>
    </div>
  </div>
</Base>
