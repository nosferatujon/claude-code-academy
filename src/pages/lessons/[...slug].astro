---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { domainName } from '../../data/domains';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map((lesson) => ({
    params: { slug: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);
---

<Base title={lesson.data.title} description={lesson.data.summary}>
  <p class="muted"><a href="/lessons/">&larr; All lessons</a></p>
  <div class="meta-row">
    <span class="badge">{domainName(lesson.data.domain)}</span>
    <span>{lesson.data.minutes} min read</span>
  </div>
  <h1>{lesson.data.title}</h1>
  <article>
    <Content />
  </article>

</Base>
