---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { DOMAINS } from '../../data/domains';

const exercises = await getCollection('exercises');
const lessons = await getCollection('lessons');

const catalog = Object.fromEntries(
  DOMAINS.map((d) => [
    d.id,
    {
      name: d.name,
      ex: exercises.filter((e) => e.data.domain === d.id).length,
      lesson: lessons.filter((l) => l.data.domain === d.id).length,
    },
  ]),
);
---

<Base title="Progress">
  <h1>Your progress</h1>
  <p class="lead">Stored only in this browser. Clearing site data or switching devices resets it.</p>

  <div class="score-banner" id="overall">—</div>

  <h2>By domain</h2>
  <div class="grid cols-2" id="domains"></div>

  <h2>Practice exam history</h2>
  <div id="examHistory"><p class="muted">No attempts yet. <a href="/exam/">Take a practice exam.</a></p></div>

  <div class="toolbar" style="margin-top:2rem">
    <button class="btn secondary" id="reset">Reset all progress</button>
  </div>

  <script is:inline define:vars={{ catalog }}>
    function render() {
      const counts = window.Progress.domainCounts();
      const state = window.Progress.all();

      let totalDone = 0;
      let totalAll = 0;
      let html = '';
      for (const [id, c] of Object.entries(catalog)) {
        const done = (counts[id]?.ex || 0) + (counts[id]?.lesson || 0);
        const total = c.ex + c.lesson;
        totalDone += done;
        totalAll += total;
        const pct = total ? Math.round((done / total) * 100) : 0;
        html +=
          `<div class="card"><h3>${c.name}</h3>` +
          `<div class="progress"><span style="width:${pct}%"></span></div>` +
          `<p class="muted" style="margin-bottom:0">${counts[id]?.ex || 0}/${c.ex} exercises · ${counts[id]?.lesson || 0}/${c.lesson} lessons</p></div>`;
      }
      document.getElementById('domains').innerHTML = html;

      const opct = totalAll ? Math.round((totalDone / totalAll) * 100) : 0;
      document.getElementById('overall').textContent =
        `${totalDone}/${totalAll} items complete (${opct}%)`;

      const hist = (state.exam.history || []).slice().reverse();
      if (hist.length) {
        let rows = hist
          .map((h) => {
            const pct = Math.round((h.correct / h.total) * 100);
            const date = new Date(h.date).toLocaleString();
            return `<tr><td>${date}</td><td>${h.correct}/${h.total}</td><td>${pct}%</td><td>${pct >= 72 ? '✓' : '—'}</td></tr>`;
          })
          .join('');
        document.getElementById('examHistory').innerHTML =
          `<table class="tablelike"><thead><tr><th>When</th><th>Score</th><th>%</th><th>Pass</th></tr></thead><tbody>${rows}</tbody></table>`;
      }
    }

    document.getElementById('reset').addEventListener('click', () => {
      if (confirm('Reset all progress and exam history?')) window.Progress.reset();
    });
    render();
    document.addEventListener('progress-change', render);
  </script>
</Base>
